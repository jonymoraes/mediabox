{
  "name": "mediabox",
  "version": "1.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@swc/core",
      "cpu-features",
      "msgpackr-extract",
      "protobufjs",
      "sharp",
      "ssh2"
    ]
  },
  "description": "Unified Media Storage Engine: A flexible intermediary and S3-compatible bridge. Seamlessly manage uploads, transcoding, and quotas across Local Storage, VPS, StorageBox, or Cloud Providers",
  "author": "jonymoraes",
  "private": false,
  "license": "MIT",
  "scripts": {
    "flush-cache": "ts-node scripts/flush-cache.ts redis",
    "restart": "pnpm run reset && pnpm run migration:flush && pnpm run migration:generate initial && pnpm run migration:run && pnpm run start:dev",
    "build": "nest build",
    "build:clean": "rm -rf dist",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:unit": "jest test/unit",
    "test:int": "jest test/integration",
    "test:e2e": "jest test/e2e",
    "test:cov": "jest --coverage",
    "test:coverage": "pnpm run test:cov",
    "test:badges": "pnpm run test:coverage && jest-coverage-badges",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "clean:coverage": "rm -rf coverage",
    "test:all": "pnpm run clean:coverage && pnpm run test:coverage",
    "typeorm": "npm run build && npx typeorm -d dist/platform/config/settings/typeorm.config.js",
    "migration:flush": "ts-node scripts/flush-migrations.ts",
    "migration:create": "npm run typeorm -- migration:generate",
    "migration:generate": "ts-node scripts/migration-generate.ts",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "migration:drop": "npm run typeorm schema:drop",
    "reset": "pnpm flush-cache && pnpm migration:drop"
  },
  "dependencies": {
    "@commitlint/types": "^20.4.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-fastify": "^11.1.14",
    "@nestjs/platform-socket.io": "^11.1.16",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.14",
    "bullmq": "^5.70.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "ioredis": "^5.9.3",
    "jest-coverage-badges": "^1.1.2",
    "nestjs-i18n": "^10.6.0",
    "pg": "^8.18.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@testcontainers/postgresql": "^11.12.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "testcontainers": "^11.12.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": "test/.*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@/src/(.*)$": "<rootDir>/src/$1",
      "^@/test/(.*)$": "<rootDir>/test/$1",
      "^@/domain/(.*)$": "<rootDir>/src/domain/$1",
      "^src/(.*)$": "<rootDir>/src/$1",
      "^test/(.*)$": "<rootDir>/test/$1"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s",
      "!src/main.ts",
      "!src/**/index.ts",
      "!src/platform/**",
      "!src/**/ports/inbound/**",
      "!src/**/persistence/database/**",
      "!src/**/outbound/cache/**",
      "!src/**/outbound/queue/**",
      "!src/**/*.module.ts",
      "!src/**/*.entity-orm.ts",
      "!src/**/*.transformer.ts",
      "!src/**/*.factory.ts",
      "!src/**/*.filter.ts",
      "!src/**/*.decorator.ts",
      "!src/**/*.guard.ts",
      "!src/**/*.interceptor.ts",
      "!src/**/*.dto.ts",
      "!src/**/*.to-dto.ts",
      "!src/**/*.exceptions.ts",
      "!src/**/*.helper.ts",
      "!src/**/*.pipe.ts",
      "!src/**/*.relay.ts",
      "!src/**/*.provider.ts",
      "!src/**/*.hbs",
      "!src/**/*.port.ts",
      "!src/**/*.service.ts"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "coverageReporters": [
      "text",
      "json-summary",
      "lcov"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 80,
        "branches": 75,
        "functions": 80,
        "lines": 80
      }
    }
  }
}
